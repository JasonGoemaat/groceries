# Secrets go here
# Should be ignored by .gitignore and .dockerignore

# run JUST pocketbase and map to two volumes which will create them
# automatically if they dont' exist.  You will need to create
# the lists and listItems collections manually or import the
# schema from 
podman run -d --replace --name groceries -p 3004:8090 \
    -e POCKETBASE_ENCRYPTION_KEY=XXX \
    -e POCKETBASE_ADMIN_EMAIL=XXX \
    -e POCKETBASE_ADMIN_PASSWORD=XXX \
    -v groceries_data:/pocketbase/data:U \
    -v groceries_migrations:/pocketbase/migrations:U \
    adrianmusante/pocketbase:latest

# sample exec to run command inside docker, using -t for a tty
# and -i for interactive because this requires answering a prompt
podman exec -t -i \
    -e POCKETBASE_ENCRYPTION_KEY=XXX \
    -e POCKETBASE_ADMIN_EMAIL=XXX \
    -e POCKETBASE_ADMIN_PASSWORD=XXX \
    -w=/pocketbase \
    groceries \
    /pocketbase/scripts/pb.sh migrate collections
